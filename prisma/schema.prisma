generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id          String   @id @default(uuid())
  symbol      String
  type        String

  entryPrice  Float
  exitPrice   Float
  quantity    Int

  entryTime   DateTime?
  exitTime    DateTime?

  stopLoss    Float?
  strategy    String?
  setup       String?
  notes       String?

  rating      Int?

  // 🔥 ADVANCED
  fees        Float?      // commission
  risk        Float?      // risk per trade
  rMultiple   Float?      // reward / risk
  roi         Float?      // %

  userEmail   String
  createdAt   DateTime @default(now())
}