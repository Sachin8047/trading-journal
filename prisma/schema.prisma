generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id         String   @id @default(uuid())
  symbol     String
  type       String
  entryPrice Float
  exitPrice  Float
  quantity   Int
  stopLoss   Float
  strategy   String?
  notes      String?

  userEmail  String  

  createdAt  DateTime @default(now())
}