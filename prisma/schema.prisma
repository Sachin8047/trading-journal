generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id         String   @id @default(uuid())
  symbol     String
  type       String

  entryPrice Float
  exitPrice  Float
  quantity   Int

  entryTime  DateTime?
  exitTime   DateTime?

  // Risk system
  stopLoss   Float?
  tpLevels   Json?

  risk       Float?
  reward     Float?
  rMultiple  Float?
  roi        Float?

  // Meta
  strategy   String?
  setup      String?
  notes      String?

  rating     Int?
  fees       Float?

  userEmail  String
  createdAt  DateTime @default(now())
}